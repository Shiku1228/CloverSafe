<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.ExpenseTracker" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/primary_red</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/secondary_red</item>
        <item name="colorOnPrimaryContainer">@color/white</item>

        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/taupe</item>
        <item name="colorOnSecondary">@color/deep_black</item>

        <!-- Background/Surface colors. -->
        <item name="android:windowBackground">@color/background_beige</item>
        <item name="colorSurface">@color/background_beige</item>
        <item name="colorOnSurface">@color/deep_black</item>
        <item name="colorSurfaceVariant">@color/taupe</item>
        <item name="colorOnSurfaceVariant">@color/deep_black</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/primary_red</item>
    </style>

    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenAnimatedIcon">@drawable/loading</item>
        <item name="windowSplashScreenBackground">@color/deep_black</item>
        <item name="postSplashScreenTheme">@style/Theme.ExpenseTracker</item>
    </style>
</resources>